# riftapi configuration
#
# All variables are namespaced with RIFTAPI_ to avoid collisions in the host
# environment. Copy to .env and fill in the secrets. .env is gitignored.

# --- API server ---
RIFTAPI_API_BIND=0.0.0.0
RIFTAPI_API_PORT=8080

# --- Database ---
# Path on the container's filesystem. Mount a volume at /data in production.
RIFTAPI_DATABASE_PATH=/data/riftapi.db

# --- Scraper (used by riftapi-sync) ---
# Identifier sent in the User-Agent header. Include contact info so the
# upstream operator can reach you if your scraper misbehaves.
RIFTAPI_SCRAPE_USER_AGENT=riftapi/0.1 (+https://github.com/xalevagre7/riftapi)
# How long to wait for the upstream GET before bailing. 30s is generous.
RIFTAPI_SCRAPE_TIMEOUT_SECS=30
# How many retries with exponential backoff on transient errors (5xx, network).
RIFTAPI_SCRAPE_MAX_RETRIES=2

# --- Sync (used by riftapi-sync) ---
# The nightly timer is a host-level systemd unit (see docs/RUNBOOK.md). This
# env var is read by the sync binary for symmetry and so the alert code can
# short-circuit when alerts are disabled.
RIFTAPI_SYNC_ENABLED=false
# Health check thresholds. The sync is considered failed if fewer than this
# many cards are parsed, or if any of the comma-separated required IDs are
# missing.
RIFTAPI_SYNC_MIN_CARD_COUNT=1100
RIFTAPI_SYNC_REQUIRED_IDS=ogn-011,unl-001,sfd-001,ven-001

# --- Telegram alerts (used by riftapi-sync) ---
# When RIFTAPI_TELEGRAM_ALERTS_ENABLED=false the alert is a no-op even if
# the token is set. Useful for local dev.
RIFTAPI_TELEGRAM_ALERTS_ENABLED=true
# The bot token. Reusing an existing bot token is fine — see IMPLEMENTATION_PLAN §3.
RIFTAPI_TELEGRAM_BOT_TOKEN=
# Numeric chat ID of the maintainer. Send a message to your bot, then look up
# the chat.id from the getUpdates response.
RIFTAPI_TELEGRAM_ADMIN_CHAT_ID=

# --- Logging ---
RIFTAPI_LOG_LEVEL=info   # debug | info | warn | error
